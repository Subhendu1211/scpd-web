# SCPD-WEB backend environment (separate from case-management-system)

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=scpd_cms
DB_SSL=false

# Public/Admin JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h

# Optional default admin bootstrap (used when admin_users is empty)
# In development, backend falls back to admin@example.com/admin123 automatically.
# In production, set these explicitly to auto-create the first admin.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_ROLE=superadmin
DEFAULT_ADMIN_FULL_NAME=System Admin

# Admin OTP settings
ADMIN_RESET_OTP_EXPIRY_MINUTES=10
ADMIN_LOGIN_OTP_EXPIRY_MINUTES=10
ADMIN_LOGIN_OTP_MAX_ATTEMPTS=5
PUBLIC_LOGIN_OTP_EXPIRY_MINUTES=10
PUBLIC_LOGIN_OTP_MAX_ATTEMPTS=5

# SMTP (for email OTP + registration/complaint mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Odisha Govt SMS Gateway
GOVT_SMS_API_URL=https://govtsms.odisha.gov.in/api/api.php
GOVT_SMS_SOURCE=ODIGOV
# Optional fallback sources (comma-separated), retried when provider reports
# sender/department/template mapping mismatch.
GOVT_SMS_SOURCE_FALLBACKS=
GOVT_SMS_DEPARTMENT_ID=D056002
GOVT_SMS_TEMPLATE_ID=
GOVT_SMS_OTP_TEMPLATE_ID=1007556907987287759
GOVT_SMS_REGISTRATION_TEMPLATE_ID=1007658595469878380
GOVT_SMS_COMPLAINT_TEMPLATE_ID=1007977038878676392
GOVT_SMS_OTP_ACTION=sendOTPSMS
GOVT_SMS_DEFAULT_ACTION=singleSMS
GOVT_SMS_OTP_CONTENT="SCPD, Govt. of Odisha: {#var#} is your OTP for login to SCPD Portal. Valid for 15 minutes only. Do not disclose it to anyone. For assistance call 0674-2954518."
GOVT_SMS_REGISTRATION_CONTENT=SCPD, Govt. of Odisha: Your registration on the SCPD Portal has been completed successfully. You may now login using your registered credentials to access services. For assistance call 0674-2954518.
GOVT_SMS_COMPLAINT_CONTENT=SCPD, Govt. of Odisha: Your complaint has been successfully submitted on SCPD Portal. It will be reviewed and necessary action will be taken. For assistance call 0674-2954518.
GOVT_SMS_FORCE_COUNTRY_CODE=false
GOVT_SMS_COUNTRY_CODE=91
GOVT_SMS_STRIP_COUNTRY_CODE=true
GOVT_SMS_OTP_SEND_BOTH_ACTIONS=false
OTP_SMS_DEV_LOG_ONLY=false
OTP_SMS_GATEWAY_DEBUG_LOG=false

# Optional Twilio Verify fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_DEFAULT_COUNTRY_CODE=91
